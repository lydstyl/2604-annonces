# Google Maps API Key (optionnel - fonctionne sans clé API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Configuration (SMTP)
# Pour Gmail :
# 1. Activer la validation en 2 étapes : https://myaccount.google.com/security
# 2. Générer un mot de passe d'application : https://myaccount.google.com/apppasswords
# 3. Utiliser le mot de passe de 16 caractères (PAS votre mot de passe Gmail habituel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password_here
EMAIL_FROM=your_email@gmail.com  # Doit être identique à SMTP_USER
EMAIL_TO=lydstyl@gmail.com        # Email qui recevra les candidatures
